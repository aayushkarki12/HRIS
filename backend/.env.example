# Copy this file to .env and fill in real values. Never commit .env.

# Database
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/hris_db

# JWT Settings - generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_64_CHAR_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# App Settings
APP_NAME=HRIS System
API_V1_STR=/api/v1

# Comma-separated list of allowed frontend origins. No wildcard in production.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Email (Resend) - used for password reset links. Get a free API key at resend.com.
RESEND_API_KEY=CHANGE_ME
RESEND_FROM_EMAIL=onboarding@resend.dev
FRONTEND_URL=http://localhost:3000
